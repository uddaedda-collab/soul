rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isRoomParticipant(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/Rooms/$(roomId))
        && request.auth.uid in get(/databases/$(database)/documents/Rooms/$(roomId)).data.participants.keys();
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    match /Users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /Rooms/{roomId} {
      allow read: if signedIn() && (resource.data.visibility == 'public' || request.auth.uid in resource.data.participants.keys() || isAdmin());
      allow create: if signedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if signedIn() && (request.auth.uid in resource.data.participants.keys() || isAdmin());
      allow delete: if isAdmin();
    }

    match /Messages/{messageId} {
      allow read: if isRoomParticipant(resource.data.roomId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && isRoomParticipant(request.resource.data.roomId)
        && request.resource.data.encryptedBody is string
        && request.resource.data.nonce is string;
      allow update: if signedIn() && request.auth.uid == resource.data.senderId;
      allow delete: if signedIn() && (request.auth.uid == resource.data.senderId || isAdmin());
    }

    match /WatchHistory/{historyId} {
      allow read, write: if signedIn() && request.auth.uid == resource.data.userId;
      allow create: if signedIn() && request.auth.uid == request.resource.data.userId;
    }

    match /Calls/{callId} {
      allow read, write: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
    }

    match /Reactions/{reactionId} {
      allow read: if isRoomParticipant(resource.data.roomId) || isAdmin();
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.senderId
        && isRoomParticipant(request.resource.data.roomId);
      allow update, delete: if false;
    }

    match /SharedMedia/{mediaId} {
      allow read: if isRoomParticipant(resource.data.roomId) || isAdmin();
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.senderId
        && isRoomParticipant(request.resource.data.roomId);
      allow update, delete: if signedIn() && (request.auth.uid == resource.data.senderId || isAdmin());
    }

    match /Reports/{reportId} {
      allow create: if signedIn() && request.auth.uid == request.resource.data.reporterId;
      allow read, update, delete: if isAdmin();
    }
  }
}
